# Groq API Configuration
# Get your free API key at https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# Optional: Override the Groq transcription endpoint (defaults to Groq's OpenAI-compatible endpoint)
# VITE_GROQ_ENDPOINT=https://api.groq.com/openai/v1/audio/transcriptions

# Optional: Override the transcription model (defaults to whisper-large-v3-turbo)
# VITE_GROQ_MODEL=whisper-large-v3-turbo

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_CLOUD_SYNC=false
